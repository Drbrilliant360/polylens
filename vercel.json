{
  "installCommand": "npm --prefix polylens-ui install && npm --prefix polylens-ui/server install",
  "buildCommand": "cd polylens-ui && node scripts/vercel-build.mjs",
  "outputDirectory": "polylens-ui/dist",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
